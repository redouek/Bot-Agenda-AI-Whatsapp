# Plataforma
# Estas variaveis sao do dono do SaaS. Usuarios finais configuram telefone,
# agenda e extras pelo onboarding web.

PORT=3000
NODE_ENV=production

# Dados persistentes
CONFIG_PATH=/data/config.json
DB_PATH=/data/app.sqlite
SESSIONS_ROOT=/data/whatsapp-sessions

# OAuth em producao:
# Depois de publicar na Oracle, troque para:
# https://SEU_DOMINIO/oauth/callback
# ou http://IP_PUBLICO:3000/oauth/callback em teste sem dominio.
OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
