# ─── WhatsApp ────────────────────────────────────────────────────────────────
# Self-chat (use seu proprio numero): 5511999999999@c.us
# Grupo:                              000000000000000000@g.us
GRUPO_ASSISTENTE_ID=5511999999999@c.us

# ─── Gemini ──────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_MODEL=models/gemini-flash-latest

# ─── Google Calendar (OAuth2) ─────────────────────────────────────────────────
# Crie em console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=primary
DEFAULT_TIMEZONE=America/Sao_Paulo
# Local:  http://localhost:3000/oauth/callback
# VPS:    http://IP_DO_SERVIDOR:3000/oauth/callback
OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback

# ─── Lembretes ────────────────────────────────────────────────────────────────
# Minutos de antecedência para enviar lembrete de evento (padrão: 15)
REMINDER_MINUTES=15

# ─── football-data.org (plano free, sem custo) ────────────────────────────────
FOOTBALL_DATA_KEY=

# ─── Servidor web (painel de configuração) ────────────────────────────────────
PORT=3000
